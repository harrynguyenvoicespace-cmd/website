{
  "name": "website1",
  "main": "backend/src/index.ts",
  "compatibility_date": "2026-07-05",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "frontend",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/", "/login", "/login.html", "/app", "/app.html"]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
